{
  "auto_update": false,
  "disable_ai": true,
  "base_keymap": "SublimeText",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
    "use_smartcase_find": true,
  },
  "buffer_font_family": "Menlo",
  "buffer_font_size": 12,
  "cursor_blink": false,
  "collaboration_panel": {
    "button": false,
  },
  "project_panel": {
    "dock": "left",
  },
  "terminal": {
    "blinking": "off",
    "line_height": "standard",
    "env": {
      "VISUAL": "zed --wait",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "languages": {
    "Kotlin": {
      "enable_language_server": false,
      "language_servers": ["kotlin-lsp"],
    },
    "Lua": {
      "enable_language_server": false,
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [
            "--respect-ignores",
            "--stdin-filepath",
            "{buffer_path}",
            "-",
          ],
        },
      },
    },
    "Python": {
      "language_servers": ["ty", "ruff"],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true,
      },
    },
    "Shell Script": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": [
            "--simplify",
            "--indent",
            "4",
            "--case-indent",
            "--",
            "-",
          ],
        },
      },
    },
  },
  "lsp": {
    "hls": {
      "initialization_options": {
        "haskell": {
          "formattingProvider": "fourmolu",
          "cabalFormattingProvider": "cabal-gild",
          "plugin": {
            "rename": {
              "config": {
                "crossModule": true,
              },
            },
          },
        },
      },
    },
  },
}
