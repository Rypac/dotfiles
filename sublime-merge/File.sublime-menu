[
    { "id": "forge", "caption": "-" },
    {
        "caption": "Open in Remote…",
        "command": "git",
        "args": { "argv": ["forge", "file", "$path"] }
    },
    {
        "caption": "Copy URL to Remote",
        "command": "git",
        "args": { "argv": ["forge", "--copy", "file", "$path"] }
    },
    {
        "caption": "Copy Permalink to Remote",
        "command": "git",
        "args": { "argv": ["forge", "--copy", "file", "$path", "--permalink", "$commit"] }
    }
]
